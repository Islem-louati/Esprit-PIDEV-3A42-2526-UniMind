{# templates/etudiant/mes_reponses/index.html.twig #}
{% extends 'base_etudiant.html.twig' %}

{% block title %}Mes Réponses{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1 class="mb-4">📋 Mes Réponses</h1>

    <!-- Filtres -->
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                
                <!-- Type -->
                <div class="col-md-4">
                    <label class="form-label fw-bold">📊 Rechercher par Type</label>
                    <select name="type" class="form-select">
                        <option value="">Tous les types</option>
                        {% for type in types_questionnaire|default([]) %}
                            <option value="{{ type }}" {{ (filters.type|default('')) == type ? 'selected' : '' }}>
                                {{ type }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <!-- Trier par Date -->
                <div class="col-md-4">
                    <label class="form-label fw-bold">📅 Trier par Date</label>
                    <select name="sort" class="form-select">
                        <option value="created_at_desc" {{ (filters.sort|default('created_at_desc')) == 'created_at_desc' ? 'selected' : '' }}>
                            Plus récent d'abord
                        </option>
                        <option value="created_at_asc" {{ (filters.sort|default('')) == 'created_at_asc' ? 'selected' : '' }}>
                            Plus ancien d'abord
                        </option>
                    </select>
                </div>

                <!-- Boutons -->
                <div class="col-md-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-filter"></i> Filtrer
                    </button>
                    <a href="{{ path('etudiant_mes_reponses') }}" class="btn btn-secondary w-100">
                        <i class="fas fa-times"></i> Réinitialiser
                    </a>
                </div>

            </form>
        </div>
    </div>

    <!-- Statistiques -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-primary">
                <div class="card-body">
                    <h3 class="text-primary">{{ total_reponses|default(0) }}</h3>
                    <p class="text-muted mb-0">Total Réponses</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-info">
                <div class="card-body">
                    <h3 class="text-info">{{ score_moyen|default(0) }}</h3>
                    <p class="text-muted mb-0">Score Moyen</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-success">
                <div class="card-body">
                    <h3 class="text-success">{{ meilleur_score|default(0) }}</h3>
                    <p class="text-muted mb-0">Meilleur Score</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-warning">
                <div class="card-body">
                    <h3 class="text-warning">{{ (stats_par_type|default([]))|length }}</h3>
                    <p class="text-muted mb-0">Types différents</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Liste des réponses -->
    {% if reponses is defined and reponses|length > 0 %}
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>📝 Questionnaire</th>
                                <th>📊 Type</th>
                                <th>📅 Date</th>
                                <th>🏆 Score</th>
                                <th>🌡️ Météo</th>
                                <th>📊 Niveau</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for reponse in reponses %}
                                {% set scoreMax = reponse.questionnaire.questions|length * 4 %}
                                {% set pct = scoreMax > 0 ? (reponse.scoreTotale / scoreMax * 100) : 0 %}
                                <tr>
                                    <td><strong>{{ reponse.questionnaire.nom }}</strong></td>
                                    <td>
                                        <span class="badge bg-primary">
                                            {{ reponse.questionnaire.type }}
                                        </span>
                                    </td>
                                    <td>{{ reponse.createdAt|date('d/m/Y H:i') }}</td>
                                    <td><strong>{{ reponse.scoreTotale }}/{{ scoreMax }}</strong></td>
                                    <td>
                                        {% if pct <= 33 %}☀️ Ensoleillé
                                        {% elseif pct <= 66 %}⛅ Nuageux
                                        {% else %}⛈️ Orageux
                                        {% endif %}
                                    </td>
                                    <td>
                                        <span class="badge bg-{{ 
                                            reponse.niveau == 'léger' ? 'success' :
                                            (reponse.niveau == 'modéré' ? 'warning' : 'danger')
                                        }}">
                                            {{ reponse.niveau }}
                                        </span>
                                    </td>
                                    <td>
                                        <a href="{{ path('etudiant_mes_reponses_detail', {'id': reponse.reponseQuestionnaireId}) }}" 
                                           class="btn btn-sm btn-info">
                                            <i class="fas fa-eye"></i> Détails
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Pagination -->
        {% if total_pages is defined and total_pages > 1 %}
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    {% if current_page > 1 %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('etudiant_mes_reponses', filters|merge({'page': current_page - 1})) }}">
                                &laquo; Précédent
                            </a>
                        </li>
                    {% endif %}
                    {% for page in 1..total_pages %}
                        <li class="page-item {{ page == current_page ? 'active' : '' }}">
                            <a class="page-link" href="{{ path('etudiant_mes_reponses', filters|merge({'page': page})) }}">
                                {{ page }}
                            </a>
                        </li>
                    {% endfor %}
                    {% if current_page < total_pages %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('etudiant_mes_reponses', filters|merge({'page': current_page + 1})) }}">
                                Suivant &raquo;
                            </a>
                        </li>
                    {% endif %}
                </ul>
            </nav>
        {% endif %}

    {% else %}
        <div class="alert alert-info text-center py-5">
            <i class="fas fa-clipboard-list fa-3x mb-3"></i>
            <h4>Aucune réponse trouvée</h4>
            <p>Aucun résultat ne correspond à votre recherche.</p>
            <a href="{{ path('etudiant_questionnaire_liste') }}" class="btn btn-primary">
                <i class="fas fa-clipboard-list"></i> Passer un questionnaire
            </a>
        </div>
    {% endif %}

</div>
{% endblock %}