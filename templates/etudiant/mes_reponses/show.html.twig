{% extends 'base_etudiant.html.twig' %}

{% block title %}Détail de la réponse{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="h3 text-dark">{{ reponse.questionnaire.nom }}</h1>
                    <p class="text-muted">Soumis le {{ reponse.createdAt|date('d/m/Y à H:i') }}</p>
                </div>
                <a href="{{ path('etudiant_mes_reponses') }}" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Retour à la liste
                </a>
            </div>

            {# Météo de l'humeur #}
            {% set scoreMax = reponse.questionnaire.questions|length * 4 %}
            {% set pourcentageExact = scoreMax > 0 ? (reponse.scoreTotale / scoreMax * 100) : 0 %}

            {% if pourcentageExact <= 33 %}
                {% set meteo = '☀️' %}
                {% set meteoTitre = 'Ensoleillé' %}
                {% set meteoCouleur = 'success' %}
                {% set meteoMessage = 'Votre humeur est au beau fixe ! Continuez comme ça !' %}
                {% set meteoFond = '#fff9c4' %}
            {% elseif pourcentageExact <= 66 %}
                {% set meteo = '⛅' %}
                {% set meteoTitre = 'Nuageux' %}
                {% set meteoCouleur = 'warning' %}
                {% set meteoMessage = 'Quelques nuages à l\'horizon. Prenez soin de vous !' %}
                {% set meteoFond = '#ffe0b2' %}
            {% else %}
                {% set meteo = '⛈️' %}
                {% set meteoTitre = 'Orageux' %}
                {% set meteoCouleur = 'danger' %}
                {% set meteoMessage = 'Tempête émotionnelle détectée. N\'hésitez pas à consulter un professionnel !' %}
                {% set meteoFond = '#ffcdd2' %}
            {% endif %}

            <div class="card mb-4 border-{{ meteoCouleur }}" style="background-color: {{ meteoFond }};">
                <div class="card-body text-center py-4">
                    <div style="font-size: 5rem;">{{ meteo }}</div>
                    <h2 class="text-{{ meteoCouleur }} fw-bold mt-2">Météo de l'humeur : {{ meteoTitre }}</h2>
                    <p class="fs-5 text-dark">{{ meteoMessage }}</p>
                    <div class="badge bg-{{ meteoCouleur }} fs-6 px-3 py-2">
                        🌡️ Score : {{ reponse.scoreTotale }}/{{ scoreMax }} ({{ pourcentageExact|round }}%)
                    </div>
                </div>
            </div>

            <!-- Résumé -->
            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="card bg-primary text-white">
                        <div class="card-body text-center">
                            <h5>Score total</h5>
                            <h2>{{ reponse.scoreTotale }}</h2>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-info text-white">
                        <div class="card-body text-center">
                            <h5>Niveau</h5>
                            <h2 class="text-uppercase">{{ reponse.niveau }}</h2>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-success text-white">
                        <div class="card-body text-center">
                            <h5>Interprétation</h5>
                            <p class="mb-0">{{ reponse.interpretation }}</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Détail des réponses -->
            <div class="card shadow">
                <div class="card-header">
                    <h5 class="mb-0">Détail de vos réponses</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Question</th>
                                    <th>Réponse</th>
                                    <th>Score</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for detail in reponses_detaillees %}
                                    <tr>
                                        <td>{{ loop.index }}</td>
                                        <td>{{ detail.question_texte }}</td>
                                        <td>
                                            {% if detail.reponse is iterable %}
                                                {{ detail.reponse|json_encode }}
                                            {% else %}
                                                {{ detail.reponse }}
                                            {% endif %}
                                        </td>
                                        <td>
                                            <span class="badge bg-{{ 
                                                detail.score < 2 ? 'success' : 
                                                (detail.score < 3 ? 'warning' : 'danger') 
                                            }}">
                                                {{ detail.score }}/4
                                            </span>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                            <tfoot>
                                <tr class="table-primary">
                                    <th colspan="3" class="text-end">Score total:</th>
                                    <th>{{ reponse.scoreTotale }}/{{ scoreMax }}</th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
            <a href="{{ path('etudiant_mes_reponses_pdf', {'id': reponse.reponseQuestionnaireId}) }}"
   class="btn btn-danger">
    <i class="fas fa-file-pdf me-2"></i>Télécharger PDF
</a>

        </div>
    </div>
</div>
{% endblock %}