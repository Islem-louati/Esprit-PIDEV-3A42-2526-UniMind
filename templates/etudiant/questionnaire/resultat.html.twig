{# templates/etudiant/questionnaire/resultat.html.twig #}
{% extends 'base_etudiant.html.twig' %}

{% block body %}
<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h2 class="mb-0">Résultat : {{ questionnaire.nom }}</h2>
        </div>
        <div class="card-body">

            {% set pourcentageExact = (score / scoreMax * 100) %}

            {# Météo de l'humeur #}
            {% if pourcentageExact <= 33 %}
                {% set meteo = '☀️' %}
                {% set meteoTitre = 'Ensoleillé' %}
                {% set meteoCouleur = 'success' %}
                {% set meteoMessage = 'Votre humeur est au beau fixe ! Continuez comme ça !' %}
                {% set meteoFond = '#fff9c4' %}
            {% elseif pourcentageExact <= 66 %}
                {% set meteo = '⛅' %}
                {% set meteoTitre = 'Nuageux' %}
                {% set meteoCouleur = 'warning' %}
                {% set meteoMessage = 'Quelques nuages à l\'horizon. Prenez soin de vous !' %}
                {% set meteoFond = '#ffe0b2' %}
            {% else %}
                {% set meteo = '⛈️' %}
                {% set meteoTitre = 'Orageux' %}
                {% set meteoCouleur = 'danger' %}
                {% set meteoMessage = 'Tempête émotionnelle détectée. N\'hésitez pas à consulter un professionnel !' %}
                {% set meteoFond = '#ffcdd2' %}
            {% endif %}

            {# Carte Météo de l'humeur #}
            <div class="card mb-4 border-{{ meteoCouleur }}" style="background-color: {{ meteoFond }};">
                <div class="card-body text-center py-4">
                    <div style="font-size: 5rem;">{{ meteo }}</div>
                    <h2 class="text-{{ meteoCouleur }} fw-bold mt-2">{{ meteoTitre }}</h2>
                    <p class="fs-5 text-dark">{{ meteoMessage }}</p>
                    <div class="badge bg-{{ meteoCouleur }} fs-6 px-3 py-2">
                        🌡️ Score : {{ score }}/{{ scoreMax }} ({{ pourcentageExact|round }}%)
                    </div>
                </div>
            </div>

            {# Détails #}
            <div class="row mt-3">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-body">
                            <p><strong>Score :</strong> {{ score }}/{{ scoreMax }}</p>
                            <p><strong>Pourcentage :</strong> {{ pourcentage }}%</p>
                            <p><strong>Niveau :</strong> {{ niveau }}</p>
                            <p><strong>Date :</strong> {{ reponse.dateSoumission|date('d/m/Y H:i') }}</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-body">
                            <h5>💬 Interprétation</h5>
                            <p>{{ interpretation }}</p>
                        </div>
                    </div>
                </div>
            </div>

            <a href="{{ path('etudiant_questionnaire_liste') }}" class="btn btn-primary mt-3">
                ← Retour aux questionnaires
            </a>
        </div>
    </div>
</div>
{% endblock %}